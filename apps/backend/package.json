{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "bun src/seed.ts && bun --watch src/index.ts",
    "seed": "bun src/seed.ts",
    "build": "bun build src/index.ts --outdir ./dist",
    "deploy": "wrangler deploy",
    "d1:migrate:local": "wrangler d1 migrations apply pw-asist --local",
    "d1:migrate": "wrangler d1 migrations apply pw-asist"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.30.10",
    "hono": "^4.12.9"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "drizzle-kit": "^0.21.0",
    "wrangler": "^3.0.0"
  }
}
